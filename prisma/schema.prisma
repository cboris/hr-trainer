// Prisma schema for Job Trainer AI
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USERS & AUTH =====
model User {
  id            String    @id @default(uuid())
  email         String    @unique @db.VarChar(255)
  name          String?   @db.VarChar(255)
  avatarUrl     String?   @map("avatar_url") @db.Text
  authProvider  String    @default("nextauth") @map("auth_provider") @db.VarChar(50)
  authExtId     String?   @map("auth_ext_id") @db.VarChar(255)
  plan          String    @default("free") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  profile             Profile?
  skills              Skill[]
  experiences         Experience[]
  educations          Education[]
  certifications      Certification[]
  jobs                Job[]
  documents           Document[]
  trainingSessions    TrainingSession[]
  conversations       Conversation[]
  checklists          Checklist[]
  profileEmbeddings   ProfileEmbedding[]
  memoryEmbeddings    MemoryEmbedding[]

  @@map("users")
}

// ===== PROFILE =====
model Profile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  headline        String?   @db.VarChar(500)
  summary         String?   @db.Text
  yearsExperience Int?      @map("years_experience")
  location        String?   @db.VarChar(255)
  locationType    String?   @map("location_type") @db.VarChar(50)
  salaryMin       Int?      @map("salary_min")
  salaryMax       Int?      @map("salary_max")
  salaryCurrency  String    @default("USD") @map("salary_currency") @db.VarChar(3)
  linkedinUrl     String?   @map("linkedin_url") @db.Text
  portfolioUrl    String?   @map("portfolio_url") @db.Text
  githubUrl       String?   @map("github_url") @db.Text
  isComplete      Boolean   @default(false) @map("is_complete")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ===== SKILLS =====
model Skill {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  name        String    @db.VarChar(255)
  category    String?   @db.VarChar(100)
  level       String?   @db.VarChar(20)
  yearsUsed   Decimal?  @map("years_used") @db.Decimal(3, 1)
  endorsed    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("skills")
}

// ===== WORK EXPERIENCE =====
model Experience {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  company       String    @db.VarChar(255)
  title         String    @db.VarChar(255)
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  isCurrent     Boolean   @default(false) @map("is_current")
  description   String?   @db.Text
  bullets       Json?
  achievements  Json?
  embeddingId   String?   @map("embedding_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

// ===== EDUCATION =====
model Education {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  institution String?   @db.VarChar(255)
  degree      String?   @db.VarChar(255)
  field       String?   @db.VarChar(255)
  startYear   Int?      @map("start_year")
  endYear     Int?      @map("end_year")
  gpa         Decimal?  @db.Decimal(3, 2)
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("educations")
}

// ===== CERTIFICATIONS =====
model Certification {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String?   @db.VarChar(255)
  issuer       String?   @db.VarChar(255)
  issuedDate   DateTime? @map("issued_date") @db.Date
  expiryDate   DateTime? @map("expiry_date") @db.Date
  credentialId String?   @map("credential_id") @db.VarChar(255)
  url          String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

// ===== JOBS =====
model Job {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  externalId      String?   @map("external_id") @db.VarChar(255)
  source          String?   @db.VarChar(100)
  sourceUrl       String?   @map("source_url") @db.Text
  title           String    @db.VarChar(255)
  company         String?   @db.VarChar(255)
  location        String?   @db.VarChar(255)
  salaryRange     String?   @map("salary_range") @db.VarChar(100)
  rawDescription  String?   @map("raw_description") @db.Text
  parsedSkills    Json?     @map("parsed_skills")
  seniority       String?   @db.VarChar(50)
  embeddingId     String?   @map("embedding_id")
  status          String    @default("saved") @db.VarChar(30)
  matchScore      Int?      @map("match_score")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents        Document[]
  trainingSessions TrainingSession[]
  checklists       Checklist[]
  jobEmbeddings    JobEmbedding[]

  @@index([userId, status])
  @@map("jobs")
}

// ===== DOCUMENTS =====
model Document {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  jobId        String?   @map("job_id")
  type         String    @db.VarChar(30)
  title        String?   @db.VarChar(255)
  contentJson  Json?     @map("content_json")
  contentMd    String?   @map("content_md") @db.Text
  contentHtml  String?   @map("content_html") @db.Text
  templateId   String?   @map("template_id") @db.VarChar(100)
  version      Int       @default(1)
  isActive     Boolean   @default(false) @map("is_active")
  s3Key        String?   @map("s3_key") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id])

  @@map("documents")
}

// ===== TRAINING SESSIONS =====
model TrainingSession {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  jobId       String?    @map("job_id")
  type        String     @db.VarChar(50)
  status      String     @default("active") @db.VarChar(30)
  config      Json?
  score       Int?
  feedback    String?    @db.Text
  startedAt   DateTime   @default(now()) @map("started_at")
  completedAt DateTime?  @map("completed_at")

  // Relations
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  job        Job?               @relation(fields: [jobId], references: [id])
  responses  InterviewResponse[]

  @@map("training_sessions")
}

// ===== INTERVIEW RESPONSES =====
model InterviewResponse {
  id           String    @id @default(uuid())
  sessionId    String    @map("session_id")
  question     String    @db.Text
  questionType String?   @map("question_type") @db.VarChar(50)
  answer       String?   @db.Text
  score        Int?
  feedback     String?   @db.Text
  improvements Json?
  durationSec  Int?      @map("duration_sec")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_responses")
}

// ===== CONVERSATIONS =====
model Conversation {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  agentType   String?   @map("agent_type") @db.VarChar(50)
  contextType String?   @map("context_type") @db.VarChar(50)
  contextId   String?   @map("context_id")
  title       String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

// ===== MESSAGES =====
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  role            String    @db.VarChar(20)
  content         String    @db.Text
  toolCalls       Json?     @map("tool_calls")
  toolResults     Json?     @map("tool_results")
  tokensUsed      Int?      @map("tokens_used")
  model           String?   @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ===== CHECKLISTS =====
model Checklist {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  jobId     String?   @map("job_id")
  title     String?   @db.VarChar(255)
  items     Json
  progress  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id])

  @@map("checklists")
}

// ===== VECTOR EMBEDDINGS (pgvector) =====
// Note: These tables use raw SQL for vector operations
// Prisma doesn't natively support pgvector, so we use
// raw queries via $executeRaw and $queryRaw

model ProfileEmbedding {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  contentType String    @map("content_type") @db.VarChar(50)
  sourceId    String?   @map("source_id")
  content     String    @db.Text
  // embedding column is vector(1536) - managed via raw SQL
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile_embeddings")
}

model JobEmbedding {
  id          String    @id @default(uuid())
  jobId       String    @map("job_id")
  contentType String?   @map("content_type") @db.VarChar(50)
  content     String    @db.Text
  // embedding column is vector(1536) - managed via raw SQL
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_embeddings")
}

model MemoryEmbedding {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  conversationId String?   @map("conversation_id")
  contentType    String?   @map("content_type") @db.VarChar(50)
  content        String    @db.Text
  // embedding column is vector(1536) - managed via raw SQL
  importance     Float     @default(0.5)
  accessCount    Int       @default(0) @map("access_count")
  lastAccessed   DateTime  @default(now()) @map("last_accessed")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memory_embeddings")
}